{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/auth/$1"
    },
    {
      "src": "/api/boards/(.*)",
      "dest": "/api/boards.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}